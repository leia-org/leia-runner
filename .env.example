PORT=5002
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
REDIS_URL=redis://localhost:6379
DEFAULT_MODEL=openai-responses
RUNNER_KEY=R2D2C3PO

# Conversation History (Generic)
CONVERSATION_HISTORY_MAX_MESSAGES=60

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_EVALUATION_MODEL=gemma3:4b
OLLAMA_HISTORY_MAX_MESSAGES=60

# ALMA Configuration
# ALMA_HOST:       Base URL of the ALMA service
# ALMA_MODEL:      Full model ID sent in the request body (e.g. meta-llama/Llama-3.1-8B-Instruct)
# ALMA_MODEL_NAME: URL path segment for the model endpoint (e.g. llama-3.1-8b-instruct)
# ALMA_API_KEY:    API key sent as the 'apikey' header
ALMA_HOST=https://alma.us.es
ALMA_MODEL=meta-llama/Llama-3.1-8B-Instruct
ALMA_MODEL_NAME=llama-3.1-8b-instruct
ALMA_API_KEY=
ALMA_MAX_TOKENS=512
ALMA_TEMPERATURE=0.7

# OAS Telemetry env variables
# All environment variables are OPTIONAL
# BOOT CONFIGURATION ---------------------------------------------------
# These variables are used at the import of the library.
# ----------------------------------------------------------------------
# Environment mode | Possible values: "production", "development", "test" | Default: "production"
OASTLM_BOOT_ENV=
# Disable the module | Possible values: "true", "false" | Default: "false"
OASTLM_BOOT_MODULE_DISABLED=
# Logging level for the boot process | Possible values: "DEBUG", "INFO", "WARNING", "ERROR", "NONE" | Default: "INFO"
OASTLM_BOOT_LOG_LEVEL=
# The name of your application or service | Default: "SERVICE-<random-uuid>"
OASTLM_BOOT_SERVICE_NAME=

# CONFIGURATION --------------------------------------------------------
# These variables are used to override the configuration when oasTelemetry(config) is called.
# ----------------------------------------------------------------------
# Base URL for telemetry | Default: "/telemetry"
OASTLM_CONFIG_GENERAL_BASE_URL=
# Specification file name | Default: null
OASTLM_CONFIG_GENERAL_SPEC_FILE_NAME=
# Enable authentication | Possible values: "true", "false" | Default: "false"
OASTLM_CONFIG_AUTH_ENABLED=
# Password for authentication | Default: "oas-telemetry-password"
OASTLM_CONFIG_AUTH_PASSWORD=
# JWT secret for authentication | Default: "oas-telemetry-secret"
OASTLM_CONFIG_AUTH_JWT_SECRET=
# Access token max age (ms) | Default: 300000 (5 minutes)
OASTLM_CONFIG_AUTH_ACCESS_TOKEN_MAX_AGE=
# Refresh token max age (ms) | Default: 604800000 (7 days)
OASTLM_CONFIG_AUTH_REFRESH_TOKEN_MAX_AGE=
# Enable memory exporter for traces | Possible values: "true", "false" | Default: "true"
OASTLM_CONFIG_TRACES_MEMORY_EXPORTER_ENABLED=
# Retention time for memory exporter (s) | Default: 3600 (1 hour)
OASTLM_CONFIG_TRACES_MEMORY_EXPORTER_RETENTION_TIME_SECONDS=
# Export interval for main metric reader (ms) | Default: 60000 (60 seconds)
OASTLM_CONFIG_METRICS_MAIN_READER_EXPORT_INTERVAL=
# Enable memory exporter for metrics | Possible values: "true", "false" | Default: "true"
OASTLM_CONFIG_METRICS_MEMORY_EXPORTER_ENABLED=
# Retention time for memory exporter (s) | Default: 3600 (1 hour)
OASTLM_CONFIG_METRICS_MEMORY_EXPORTER_RETENTION_TIME_SECONDS=
# Enable memory exporter for logs | Possible values: "true", "false" | Default: "true"
OASTLM_CONFIG_LOGS_MEMORY_EXPORTER_ENABLED=
# Retention time for memory exporter (s) | Default: 3600 (1 hour)
OASTLM_CONFIG_LOGS_MEMORY_EXPORTER_RETENTION_TIME_SECONDS=
# OpenAI API key | Default: null
OASTLM_CONFIG_AI_OPENAI_KEY=
# OpenAI model name | Default: "gpt-3.5-turbo"
OASTLM_CONFIG_AI_OPENAI_MODEL=
# Extra context prompts for AI | Default: empty (e.g., "Prompt1,Prompt2")
OASTLM_CONFIG_AI_EXTRA_CONTEXT_PROMPTS=

